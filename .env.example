# ── Alchemy ───────────────────────────────────────────────────────────────────
ALCHEMY_API_KEY=YOUR_ALCHEMY_API_KEY
ALCHEMY_POLICY_ID=YOUR_ALCHEMY_POLICY_ID
# ALCHEMY_BSO_POLICY_ID=YOUR_ALCHEMY_BSO_POLICY_ID   # optional: enables alchemy-mav2-bso
# ALCHEMY_RPC_URL=YOUR_ALCHEMY_RPC_URL               # optional: overrides the chain-specific URL derived from NETWORK + API key

# ── Pimlico ───────────────────────────────────────────────────────────────────
PIMLICO_API_KEY=YOUR_PIMLICO_API_KEY
PIMLICO_POLICY_ID=YOUR_PIMLICO_POLICY_ID
# PIMLICO_RPC_URL=YOUR_PIMLICO_RPC_URL

# ── ZeroDev ───────────────────────────────────────────────────────────────────
ZERODEV_API_KEY=YOUR_ZERODEV_API_KEY
ZERODEV_PROJECT_ID=YOUR_ZERODEV_PROJECT_ID
# ZERODEV_RPC_URL=YOUR_ZERODEV_RPC_URL

# ── Owner key (stable account) ───────────────────────────────────────────────
# Required for the monitor; enables stable deterministic owner accounts so every
# run measures steady-state latency on an already-deployed account (self-bootstrap).
# Optional for the CLI — when unset, adapters fall back to per-run random keys.
OWNER_PRIVATE_KEY=YOUR_OWNER_PRIVATE_KEY

# ── Neutral canonical oracle ──────────────────────────────────────────────────
# Used ONLY by the canonical oracle (getLogs / getBlockNumber / getTransactionReceipt).
# OPTIONAL: when unset, the monitor/CLI defaults to the Alchemy chain-specific URL
# (https://<NETWORK>.g.alchemy.com/v2/<API key>). This is allowed because all monitor
# adapters are Alchemy, so no contestant is disadvantaged; the preflight emits a
# warning instead of erroring. Set this to a truly independent node ONLY for mixed-
# provider runs (Alchemy + Pimlico/ZeroDev) where neutrality is required for fairness.
# NEUTRAL_RPC_URL=YOUR_NEUTRAL_RPC_URL
# NEUTRAL_FLASHBLOCK_WS_URL=YOUR_NEUTRAL_FLASHBLOCK_WS_URL

# ── Optional settings (uncomment to override defaults) ────────────────────────
# RUN_COUNT=5
# TIMEOUT_SUBMIT_MS=30000
# TIMEOUT_PRECONF_MS=30000
# TIMEOUT_CANONICAL_MS=120000
# TIMEOUT_RECEIPT_MS=120000
